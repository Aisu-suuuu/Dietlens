# DietLens — Environment Variables Template
# Copy this file to .env.local and fill in the real values from your Supabase project.
# See docs/supabase-setup.md Step 5 for where to find each value.
#
# NEVER commit .env.local to git — it is already in .gitignore.
# Add these same three vars to Vercel (Settings → Environment Variables) for production.

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------

# Your Supabase project URL — found in Project Settings → API → Project URL
# Format: https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous/public key — safe to expose in the browser bundle.
# Found in Project Settings → API → Project API Keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — KEEP SECRET. Never prefix with NEXT_PUBLIC_.
# Only used in server-side API routes (Vercel Cron, /api/* handlers).
# Found in Project Settings → API → Project API Keys → service_role
# In Vercel: add this under Settings → Environment Variables (not in code).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
